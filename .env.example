# Aletheia Beyond Environment Configuration
# ==========================================
# Copy to .env and fill in your values
#
# SECURITY WARNING: Never commit .env to version control

# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────

# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/aletheia

# SQLite (development fallback — uncomment to use)
# DATABASE_URL=sqlite+aiosqlite:///./aletheia.db

# Set to "true" to use in-memory storage (for testing without DB)
USE_IN_MEMORY_DB=false

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production

# Token lifetime in hours (default: 24)
JWT_TOKEN_LIFETIME_HOURS=24

# ─────────────────────────────────────────────────────────────
# OPENAI API
# ─────────────────────────────────────────────────────────────

# Required for live COBOL analysis (offline stubs used if missing)
OPENAI_API_KEY=sk-your-openai-api-key

# ─────────────────────────────────────────────────────────────
# EMAIL (Optional)
# ─────────────────────────────────────────────────────────────

SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-password

# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────

# Maximum file upload size in MB
MAX_FILE_SIZE_MB=10

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
