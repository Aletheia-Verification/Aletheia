       IDENTIFICATION DIVISION.
       PROGRAM-ID. TAX-FOREIGN-CREDIT.
       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       SPECIAL-NAMES.
           DECIMAL-POINT IS COMMA.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01 WS-INCOME-DATA.
           05 WS-TOTAL-INCOME        PIC S9(9)V99 COMP-3.
           05 WS-FOREIGN-INCOME      PIC S9(9)V99 COMP-3.
           05 WS-FOREIGN-TAX-PAID    PIC S9(7)V99 COMP-3.
       01 WS-US-TAX                  PIC S9(7)V99 COMP-3.
       01 WS-CREDIT-FIELDS.
           05 WS-CREDIT-LIMIT        PIC S9(7)V99 COMP-3.
           05 WS-ALLOWABLE-CREDIT    PIC S9(7)V99 COMP-3.
           05 WS-CARRYFORWARD        PIC S9(7)V99 COMP-3.
       01 WS-FOREIGN-RATIO           PIC S9(1)V9(6) COMP-3.
       01 WS-TAX-RATE                PIC S9(1)V9(4) COMP-3
           VALUE 0,2200.
       PROCEDURE DIVISION.
       0000-MAIN-PROCESS.
           PERFORM 1000-INITIALIZE
           PERFORM 2000-CALC-LIMIT
           PERFORM 3000-DETERMINE-CREDIT
           PERFORM 4000-DISPLAY-RESULTS
           STOP RUN.
       1000-INITIALIZE.
           MOVE 0 TO WS-CREDIT-LIMIT
           MOVE 0 TO WS-ALLOWABLE-CREDIT
           MOVE 0 TO WS-CARRYFORWARD.
       2000-CALC-LIMIT.
           IF WS-TOTAL-INCOME > 0
               COMPUTE WS-FOREIGN-RATIO =
                   WS-FOREIGN-INCOME / WS-TOTAL-INCOME
           END-IF
           COMPUTE WS-US-TAX =
               WS-TOTAL-INCOME * WS-TAX-RATE
           COMPUTE WS-CREDIT-LIMIT =
               WS-US-TAX * WS-FOREIGN-RATIO.
       3000-DETERMINE-CREDIT.
           IF WS-FOREIGN-TAX-PAID <= WS-CREDIT-LIMIT
               MOVE WS-FOREIGN-TAX-PAID TO
                   WS-ALLOWABLE-CREDIT
               MOVE 0 TO WS-CARRYFORWARD
           ELSE
               MOVE WS-CREDIT-LIMIT TO
                   WS-ALLOWABLE-CREDIT
               COMPUTE WS-CARRYFORWARD =
                   WS-FOREIGN-TAX-PAID - WS-CREDIT-LIMIT
           END-IF.
       4000-DISPLAY-RESULTS.
           DISPLAY 'FOREIGN TAX CREDIT'
           DISPLAY '=================='
           DISPLAY 'TOTAL INCOME:     ' WS-TOTAL-INCOME
           DISPLAY 'FOREIGN INCOME:   ' WS-FOREIGN-INCOME
           DISPLAY 'FOREIGN TAX PAID: ' WS-FOREIGN-TAX-PAID
           DISPLAY 'US TAX:           ' WS-US-TAX
           DISPLAY 'CREDIT LIMIT:     ' WS-CREDIT-LIMIT
           DISPLAY 'ALLOWABLE CREDIT: ' WS-ALLOWABLE-CREDIT
           IF WS-CARRYFORWARD > 0
               DISPLAY 'CARRYFORWARD:     ' WS-CARRYFORWARD
           END-IF.
