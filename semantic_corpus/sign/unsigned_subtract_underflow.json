{
  "description": "SUBTRACT going negative in unsigned field produces absolute value",
  "category": "sign",
  "inputs": {
    "WS-BALANCE": "100.00",
    "WS-DEBIT": "250.00"
  },
  "expected_outputs": {
    "WS-BALANCE": "150.00"
  },
  "notes": "100.00 - 250.00 = -150.00. PIC 9(5)V99 is unsigned, so abs(-150.00) = 150.00. cobol_types.py:118."
}
